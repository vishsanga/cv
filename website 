            </div>
        </section>

        <!-- Services -->
        <section id="services" class="section fade-in">
            <h2 class="section-title">Our Services</h2>
            <div class="services-grid">
                <div class="service-card fade-in">
                    <div class="service-icon"><i class="fas fa-globe"></i></div>
                    <h3>Website Development</h3>
                    <p>Custom business websites, portfolios, landing pages, and e-commerce platforms built with modern technologies.</p>
